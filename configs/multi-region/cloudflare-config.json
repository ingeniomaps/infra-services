{
  "description": "CloudFlare configuration for Keycloak multi-region deployment",
  "dns_records": [
    {
      "type": "A",
      "name": "keycloak",
      "content": "keycloak-use1.example.com",
      "ttl": 300,
      "proxied": true,
      "comment": "US East primary"
    },
    {
      "type": "A",
      "name": "keycloak-eu",
      "content": "keycloak-euw1.example.com",
      "ttl": 300,
      "proxied": true,
      "comment": "EU West region"
    },
    {
      "type": "A",
      "name": "keycloak-ap",
      "content": "keycloak-apse1.example.com",
      "ttl": 300,
      "proxied": true,
      "comment": "AP Southeast region"
    }
  ],
  "load_balancer": {
    "name": "keycloak-lb",
    "description": "Keycloak multi-region load balancer",
    "enabled": true,
    "ttl": 30,
    "fallback_pool": "us-east-pool",
    "default_pools": [
      "us-east-pool",
      "eu-west-pool",
      "ap-southeast-pool"
    ],
    "rules": [
      {
        "condition": "http.request.geoip.continent eq \"NA\"",
        "overrides": {
          "pools": ["us-east-pool"]
        },
        "priority": 1
      },
      {
        "condition": "http.request.geoip.continent eq \"EU\"",
        "overrides": {
          "pools": ["eu-west-pool"]
        },
        "priority": 2
      },
      {
        "condition": "http.request.geoip.continent eq \"AS\"",
        "overrides": {
          "pools": ["ap-southeast-pool"]
        },
        "priority": 3
      }
    ],
    "health_checks": {
      "path": "/health/ready",
      "interval": 30,
      "timeout": 5,
      "retries": 3,
      "expected_codes": "200"
    }
  },
  "pools": [
    {
      "name": "us-east-pool",
      "description": "US East region pool",
      "enabled": true,
      "monitor": "us-east-health-check",
      "origins": [
        {
          "name": "keycloak-use1-1",
          "address": "keycloak-use1-1.example.com",
          "enabled": true,
          "weight": 100
        },
        {
          "name": "keycloak-use1-2",
          "address": "keycloak-use1-2.example.com",
          "enabled": true,
          "weight": 100
        },
        {
          "name": "keycloak-use1-3",
          "address": "keycloak-use1-3.example.com",
          "enabled": true,
          "weight": 100
        }
      ],
      "check_regions": ["WNAM", "ENAM"],
      "minimum_origins": 1,
      "notification_email": "alerts@example.com"
    },
    {
      "name": "eu-west-pool",
      "description": "EU West region pool",
      "enabled": true,
      "monitor": "eu-west-health-check",
      "origins": [
        {
          "name": "keycloak-euw1-1",
          "address": "keycloak-euw1-1.example.com",
          "enabled": true,
          "weight": 100
        },
        {
          "name": "keycloak-euw1-2",
          "address": "keycloak-euw1-2.example.com",
          "enabled": true,
          "weight": 100
        },
        {
          "name": "keycloak-euw1-3",
          "address": "keycloak-euw1-3.example.com",
          "enabled": true,
          "weight": 100
        }
      ],
      "check_regions": ["WEU", "EEU"],
      "minimum_origins": 1,
      "notification_email": "alerts@example.com"
    },
    {
      "name": "ap-southeast-pool",
      "description": "AP Southeast region pool",
      "enabled": true,
      "monitor": "ap-southeast-health-check",
      "origins": [
        {
          "name": "keycloak-apse1-1",
          "address": "keycloak-apse1-1.example.com",
          "enabled": true,
          "weight": 100
        },
        {
          "name": "keycloak-apse1-2",
          "address": "keycloak-apse1-2.example.com",
          "enabled": true,
          "weight": 100
        },
        {
          "name": "keycloak-apse1-3",
          "address": "keycloak-apse1-3.example.com",
          "enabled": true,
          "weight": 100
        }
      ],
      "check_regions": ["SEAS", "NEAS"],
      "minimum_origins": 1,
      "notification_email": "alerts@example.com"
    }
  ],
  "health_checks": [
    {
      "name": "us-east-health-check",
      "description": "US East region health check",
      "address": "keycloak-use1.example.com",
      "type": "HTTPS",
      "port": 443,
      "path": "/health/ready",
      "interval": 30,
      "retries": 3,
      "timeout": 5,
      "expected_codes": "200",
      "follow_redirects": true,
      "allow_insecure": false
    },
    {
      "name": "eu-west-health-check",
      "description": "EU West region health check",
      "address": "keycloak-euw1.example.com",
      "type": "HTTPS",
      "port": 443,
      "path": "/health/ready",
      "interval": 30,
      "retries": 3,
      "timeout": 5,
      "expected_codes": "200",
      "follow_redirects": true,
      "allow_insecure": false
    },
    {
      "name": "ap-southeast-health-check",
      "description": "AP Southeast region health check",
      "address": "keycloak-apse1.example.com",
      "type": "HTTPS",
      "port": 443,
      "path": "/health/ready",
      "interval": 30,
      "retries": 3,
      "timeout": 5,
      "expected_codes": "200",
      "follow_redirects": true,
      "allow_insecure": false
    }
  ]
}
