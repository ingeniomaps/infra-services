{
  "id": null,
  "title": "Infraestructura - Estado General",
  "description": "Panel de control con semáforos y recomendaciones para cada servicio",
  "tags": ["overview", "infra"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
