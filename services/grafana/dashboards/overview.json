      "description": "🟢 UP = Elasticsearch respondiendo\\n🔴 DOWN = Reiniciar con: make infra-elasticsearch",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "elasticsearch_cluster_health_up", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
