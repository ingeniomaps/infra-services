  "panels": [
    {
      "type": "row",
      "title": "🔴🟡🟢 Estado de Servicios",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "PostgreSQL",
      "description": "🟢 UP = PostgreSQL respondiendo\\n🔴 DOWN = Reiniciar con: make infra-postgres",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "pg_up", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CAÍDO", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Redis",
      "description": "🟢 UP = Redis respondiendo\\n🔴 DOWN = Reiniciar con: make infra-redis",
