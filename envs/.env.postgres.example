# ============================================
# POSTGRESQL + PGBOUNCER
# ============================================

# Servidor principal
POSTGRES_DB=myapp
POSTGRES_HOST=${PROJECT_PREFIX:-postgres}${PROJECT_PREFIX:+-postgres}
POSTGRES_PORT=5432
POSTGRES_USER=myapp_user
POSTGRES_PASSWORD=

# Pool de conexiones (PgBouncer)
PGBOUNCER_HOST=${PROJECT_PREFIX:-pgbouncer}${PROJECT_PREFIX:+-pgbouncer}
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=10000
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_MIN_POOL_SIZE=10
PGBOUNCER_AUTH_TYPE=scram-sha-256

# Replica de lectura
POSTGRES_REPLICA_HOST=${PROJECT_PREFIX:-postgres-replica}${PROJECT_PREFIX:+-postgres-replica}

# Pool de conexiones (app directa)
DB_POOL_INITIAL_SIZE=10
DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=100
DB_POOL_MAX_LIFETIME=1800000
